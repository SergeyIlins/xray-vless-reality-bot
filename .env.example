# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram ID администратора (узнать через /id в боте @userinfobot)
ALLOWED_USERS=123456789

# IP-адрес или домен сервера (можно оставить auto для автоматического определения)
SERVER_IP=auto

# Публичный ключ REALITY (генерируется при установке)
PUBLIC_KEY=auto

# ShortId (генерируется при установке)
SHORT_ID=auto

# Домен для маскировки (SNI)
SNI=www.microsoft.com